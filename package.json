{
  "name": "datapilot",
  "version": "2.0.0",
  "description": "🤖 AI-companion statistical computation engine for CSV data. Provides comprehensive statistical analysis optimized for AI interpretation with advanced visualization recommendations.",
  "main": "bin/datapilot.js",
  "bin": {
    "datapilot": "./dist/datapilot.js"
  },
  "type": "module",
  "scripts": {
    "test": "node tests/test_all.js",
    "test:modern": "node tests/run_modern_tests.js",
    "test:legacy": "node tests/run_tests.js",
    "test:unit": "node tests/unit/test_columnDetector.js && node tests/unit/test_errorHandling.js",
    "test:integration": "node tests/run_modern_tests.js",
    "test:quick": "node tests/unit/test_columnDetector.js",
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "files": [
    "dist/",
    "src/",
    "bin/",
    "scripts/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "csv",
    "ai-companion",
    "statistical-engine",
    "data-analysis",
    "cli",
    "eda",
    "exploratory-data-analysis",
    "data-quality",
    "visualization",
    "llm",
    "ai-ready",
    "chatgpt",
    "claude",
    "statistical-computing",
    "data-science",
    "statistics",
    "correlation",
    "outliers",
    "advanced-analytics",
    "machine-learning",
    "insights",
    "statistical-tests"
  ],
  "author": "DataPilot Contributors",
  "homepage": "https://github.com/Mrassimo/datapilot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrassimo/datapilot.git"
  },
  "bugs": {
    "url": "https://github.com/Mrassimo/datapilot/issues"
  },
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "chardet": "^0.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.0.0",
    "csv-parse": "^5.5.0",
    "fuzzyset.js": "^1.0.7",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0",
    "jstat": "^1.9.6",
    "libphonenumber-js": "^1.12.8",
    "ml-cart": "^2.1.1",
    "ml-kmeans": "^6.0.0",
    "nanospinner": "^1.2.2",
    "ora": "^7.0.0",
    "regression": "^2.0.1",
    "simple-statistics": "^7.8.8",
    "validator": "^13.15.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "rollup": "^4.41.1",
    "rollup-plugin-preserve-shebang": "^1.0.1"
  }
}
